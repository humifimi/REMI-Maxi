{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "types": ["jest"],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@customer/*": [
        "./src/modes/customer/*"
      ],
      "@technician/*": [
        "./src/modes/technician/*"
      ],
      "@profit-model/*": [
        "vendor/profit-model/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "vendor/profit-model/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "vendor/react-native-resource-calendar",
    "vendor/react-native-draggable-flatlist",
    "**/__tests__/**"
  ]
}
