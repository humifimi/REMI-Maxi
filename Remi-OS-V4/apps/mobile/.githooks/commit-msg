#!/usr/bin/env bash
#
# .githooks/commit-msg — git-side branch-hygiene check.
#
# Single responsibility: refuse any commit on `main` or `master`.
# Mirrors .cursor/hooks/check-commit-branch.sh but fires from inside
# git itself so it catches commits made outside the Cursor agent
# (source-control panel, terminal, etc.).
#
# Activation per-clone:
#
#   ./scripts/install-hooks.sh
#
# Idempotent. Sets `git config core.hooksPath .githooks`.
#
# The old chunk-ID enforcement is retired — the master plan that
# motivated it is complete. See .cursor/rules/branch-hygiene.mdc.

set -uo pipefail

msg_file="${1:-}"
[[ -z "$msg_file" || ! -f "$msg_file" ]] && exit 0

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[[ -z "$REPO_ROOT" ]] && exit 0

# Skip merge commits — they're produced by `git merge` / rebase, not
# authored work. (Detected via .git/MERGE_MSG presence.)
if [[ -f "$REPO_ROOT/.git/MERGE_MSG" ]]; then
  exit 0
fi

# Skip amends — they edit existing commits and don't change which
# branch the commit lives on.
if [[ "${GIT_REFLOG_ACTION:-}" == *"amend"* ]]; then
  exit 0
fi

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"

if [[ "$branch" == "main" || "$branch" == "master" ]]; then
  cat >&2 <<EOF

  branch-hygiene (git commit-msg hook): refusing to commit directly to '$branch'.

  RUN THIS NEXT to branch off the current HEAD, then re-commit:

    ./scripts/check-branch-chunk.sh --create <branch-name>

  Example:
    ./scripts/check-branch-chunk.sh --create fix/oauth-token-leak

  See .cursor/rules/branch-hygiene.mdc for the full convention.

EOF
  exit 1
fi

exit 0
