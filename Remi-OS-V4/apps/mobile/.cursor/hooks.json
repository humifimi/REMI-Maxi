{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/absolutize-paths.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/check-commit-branch.sh",
        "matcher": "\\bgit\\s+commit\\b",
        "failClosed": false
      }
    ]
  }
}
