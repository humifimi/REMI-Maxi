{
  "name": "remi-os",
  "version": "1.0.0",
  "private": true,
  "description": "REMI local monorepo — Technician + Customer mobile, API, shared packages",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "mobile:android": "npm run android --workspace=apps/mobile",
    "mobile:ios": "npm run ios --workspace=apps/mobile",
    "api": "npm run dev --workspace=apps/api",
    "api:test": "npm run test --workspace=apps/api",
    "lint:mobile": "npm run lint --workspace=apps/mobile",
    "ci:local": "node scripts/ci-local.js",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "expo": "~54.0.35",
    "react-native": "0.81.5"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-test-renderer": "19.1.4"
  }
}
